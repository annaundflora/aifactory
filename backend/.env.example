# =============================================================================
# AI Factory Backend - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Do NOT commit the .env file to version control.
# =============================================================================

# --- Database ---
# PostgreSQL connection string (shared with AI Factory Next.js app)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aifactory

# --- LLM API (OpenRouter) ---
# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# --- Replicate API (for model recommendations) ---
# Get your API token at https://replicate.com/account/api-tokens
# Optional: only needed for model recommendation feature
REPLICATE_API_TOKEN=

# --- Tavily Search API (for web_search tool in Prompt Assistant) ---
# Get your API key at https://tavily.com
# Optional: only needed for web search feature (free tier: 1000 searches/month)
TAVILY_API_KEY=

# --- LangSmith Observability ---
# Get your API key at https://smith.langchain.com/settings
# Optional: only needed for tracing/debugging
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=prompt-assistant

# --- Assistant Defaults ---
# Default LLM model for the assistant
# Options: anthropic/claude-sonnet-4.6, openai/gpt-5.4, google/gemini-3.1-pro-preview
ASSISTANT_MODEL_DEFAULT=anthropic/claude-sonnet-4.6

# --- Application ---
APP_VERSION=1.0.0
