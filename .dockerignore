# Environment files (may contain secrets)
.env
.env.*

# Version control
.git

# Dependencies (re-installed during build)
node_modules
backend/.venv

# Next.js build output (rebuilt during build)
.next

# Documentation
*.md

# Docker Compose files (not needed inside image)
docker-compose*.yml

# Specs, tests, images (not needed in production image)
specs
.images
worktrees
tmp.txt

# Claude/IDE config
.claude
