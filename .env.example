# ===========================================
# AI Factory - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# All variables marked as REQUIRED must be set for the app to function.

# -----------------
# Authentication (REQUIRED unless AUTH_DISABLED=true)
# -----------------
# Set to "true" to skip all authentication in dev. Uses a fixed dev user.
# AUTH_DISABLED=true

# Secret used by Auth.js for session encryption. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth credentials from Google Cloud Console.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated list of email addresses allowed to log in.
ALLOWED_EMAILS=

# -----------------
# Database (REQUIRED)
# -----------------
# Connection string used by the application.
# Format: postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@db:5432/<POSTGRES_DB>
DATABASE_URL=

# Docker Postgres container credentials.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# -----------------
# API Keys (REQUIRED)
# -----------------
# OpenRouter API key for LLM access.
OPENROUTER_API_KEY=

# Replicate API token for image generation.
REPLICATE_API_TOKEN=

# -----------------
# Cloudflare R2 Storage (REQUIRED)
# -----------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=
# docker-compose.prod.yml passes R2_BUCKET_NAME to the container.
# The app reads R2_BUCKET_NAME first, falling back to R2_BUCKET.
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# -----------------
# Langsmith (OPTIONAL)
# -----------------
# Set LANGSMITH_TRACING=true to enable tracing.
# LANGSMITH_TRACING=false
# LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
# LANGSMITH_API_KEY=
